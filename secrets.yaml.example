# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored - never commit it.

wifi_ssid: "YourSSID"
wifi_password: "YourWifiPassword"

# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_KEY"

ota_password: "REPLACE_WITH_OTA_PASSWORD"

fallback_ap_password: "REPLACE_WITH_FALLBACK_AP_PASSWORD"
